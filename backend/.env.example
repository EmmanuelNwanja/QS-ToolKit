# ============================================================
#  QSToolkit Backend - Environment Variables
#  Copy this file to .env and fill in all values
#  NEVER commit .env to GitHub!
# ============================================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # Settings > API > service_role (SECRET)
SUPABASE_ANON_KEY=your-supabase-anon-key              # Settings > API > anon/public

# JWT (generate a long random string: openssl rand -base64 64)
JWT_SECRET=your-very-long-random-secret-key-here
JWT_EXPIRES_IN=7d

# Brevo (Email)
BREVO_API_KEY=your-brevo-api-key                      # Brevo > SMTP & API > API Keys
BREVO_SENDER_EMAIL=noreply@qstoolkit.com
BREVO_SENDER_NAME=QSToolkit

# Paystack (Nigerian Payments)
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx       # test: sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Cloudinary (optional - for logo/signature storage, or use Supabase Storage)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Production only
# DATABASE_URL=postgresql://...  (Supabase connection string if direct DB needed)
