# ============================================================
#  QSToolkit Frontend — Environment Variables
#  Copy to .env.local and fill in values
#  NEVER commit .env.local to GitHub!
# ============================================================

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Supabase (public keys only — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Paystack Public Key (safe to expose)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Frontend build version (used for service worker auto-update cache busting)
# Local/dev default; in production set this to your deploy commit SHA.
NEXT_PUBLIC_APP_VERSION=dev

# Production overrides (set in Vercel dashboard)
# NEXT_PUBLIC_API_URL=https://api.qstoolkit.com/api/v1
# NEXT_PUBLIC_APP_URL=https://qstoolkit.com
# NEXT_PUBLIC_APP_VERSION=<commit-sha>
